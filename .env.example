# Servidor
PORT=3000
NODE_ENV=development

# MongoDB Atlas
# Crie um novo cluster ou use o mesmo do HolyPleiiiz em um banco separado
# Formato: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/quizzygamez?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@SEU_CLUSTER.mongodb.net/quizzygamez?retryWrites=true&w=majority

# Segurança admin
ADMIN_SECRET=sua-chave-admin-aqui

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=150

# CORS — URLs separadas por vírgula (* para liberar tudo em dev)
ALLOWED_ORIGINS=http://localhost:8080,https://quizzygamez.netlify.app,https://holypleiiiz.netlify.app

# JWT — para SSO na Fase 3
# JWT_SECRET=sua-chave-jwt-aqui
